# AWS POC platform environment — account-specific configuration TEMPLATE.
#
# Copy this file to `sandbox.tfvars` (same directory) and fill in your own values.
# The stack scripts pick it up automatically via -var-file:
#
#     cp sandbox.tfvars.example sandbox.tfvars
#     make aws-infra-up
#
# `sandbox.tfvars` is gitignored so your account details never land in the repo.
# Override the path with AWS_TFVARS_FILE=/path/to/your.tfvars if you prefer.
# See docs/setup/cloud-poc-setup.md for the full walkthrough.
#
# Most values are inherited from the foundation contract (region, cluster, the
# "limited-" naming), so this environment only needs the mandatory tags.

# Tags applied to every resource. Many managed accounts REQUIRE a specific set of
# tags (case-sensitive) and delete untagged resources. Adjust keys/values to match
# your account policy; Owner/Requester should be YOUR email.
default_tags = {
  Project   = "openlakeforge"
  Owner     = "you@example.com"
  Requester = "you@example.com"
  Env       = "POC"
  IaC       = "Terraform"
}
