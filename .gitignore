# Terraform
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
*.tfvars.json
# Sandbox/account config is non-secret (mandatory tags + limited- naming) and is tracked.
!sandbox.tfvars
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

generated/

# dbt local artifacts
**/transformations/dbt/.user.yml
**/transformations/dbt/logs/
**/transformations/dbt/target/
**/transformations/dbt/dbt_packages/
**/transformations/dbt/*/.user.yml
**/transformations/dbt/*/package-lock.yml
**/transformations/dbt/*/logs/
**/transformations/dbt/*/target/
**/transformations/dbt/*/dbt_packages/

# Local Kubernetes and tooling
kubeconfig*
*.kubeconfig
.kube/
.kind/
.k3d/

# Logs and local outputs
*.log
tmp/
.tmp/

# Vendored patched dependencies (test-only, not for commit)
vendor/

# Terraform plans can contain sensitive values.
*.tfplan
