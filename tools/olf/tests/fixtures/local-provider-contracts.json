{
  "storage": {
    "logical_name": "lakehouse_storage",
    "provider": "local",
    "implementation": "storage.s3_compatible.seaweedfs",
    "protocol": "s3",
    "bronze_bucket_name": "lakehouse-bronze",
    "silver_bucket_name": "lakehouse-silver",
    "gold_bucket_name": "lakehouse-gold",
    "bucket_name": "lakehouse-bronze",
    "region": "us-east-1",
    "endpoint": "http://seaweedfs-s3:8333",
    "virtual_host_endpoint": "http://lakehouse.svc.cluster.local:8333",
    "path_style_access": true,
    "ssl_mode": "disabled",
    "credentials_secret_name": "seaweedfs-s3-creds",
    "access_key_id_key": "AWS_ACCESS_KEY_ID",
    "secret_access_key_key": "AWS_SECRET_ACCESS_KEY",
    "s3_service_name": "seaweedfs-s3",
    "s3_service_port": 8333
  },
  "catalog": {
    "logical_name": "iceberg_catalog",
    "implementation": "catalog.iceberg_rest.polaris",
    "catalog_type": "rest",
    "catalog_provider": "polaris",
    "catalog_name": "lakehouse_dev",
    "runtime_profile": "polaris-rest",
    "rest_uri": "http://polaris:8181/api/catalog",
    "token_uri": "http://polaris:8181/api/catalog/v1/oauth/tokens",
    "oauth_scope": "PRINCIPAL_ROLE:ALL",
    "warehouse": "lakehouse_dev",
    "catalog_namespace_model": "product-layer",
    "catalog_namespaces": [
      {
        "name": "sales_order_revenue_silver",
        "location": "s3://lakehouse-silver/sales_order_revenue_silver/"
      }
    ],
    "silver_namespaces": {
      "sales_order_revenue": "sales_order_revenue_silver"
    },
    "gold_namespaces": {
      "sales_order_revenue": "sales_order_revenue_gold"
    },
    "floe_credentials_secret_name": "polaris-floe-creds",
    "floe_client_id_key": "POLARIS_FLOE_CLIENT_ID",
    "floe_client_secret_key": "POLARIS_FLOE_CLIENT_SECRET"
  },
  "artifact_bucket": {
    "bucket_name": "openlakeforge-ops",
    "artifact_base_uri": "s3://openlakeforge-ops",
    "access_mode": "remote",
    "base_uri": "s3://openlakeforge-ops/floe/manifests",
    "floe_report_base_uri": "s3://openlakeforge-ops/floe/reports",
    "log_base_uri": "s3://openlakeforge-ops/logs",
    "run_artifact_base_uri": "s3://openlakeforge-ops/run-artifacts",
    "local_upload_access_mode": "kubectl-port-forward"
  },
  "kubernetes_platform": {
    "namespace": "lakehouse"
  },
  "query": {
    "catalog_name": "iceberg",
    "endpoint": "http://trino:8080"
  }
}
